{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "event_leaderboards": {
      "patternProperties": {
        ".+": {
          "properties": {
            "additional_properties": {
              "patternProperties": {
                ".+": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "ascending": {
              "type": "boolean"
            },
            "category": {
              "pattern": ".+",
              "type": "string"
            },
            "change_zones": {
              "patternProperties": {
                "[0-9]+": {
                  "properties": {
                    "demote_idle": {
                      "type": "boolean"
                    },
                    "demotion": {
                      "minimum": 0,
                      "type": "number"
                    },
                    "promotion": {
                      "minimum": 0,
                      "type": "number"
                    },
                    "use_max_cohort_size": {
                      "type": "boolean"
                    },
                    "promotion_reroll_count_freeze": {
                      "type": "boolean"
                    },
                    "demotion_reroll_count_freeze": {
                      "type": "boolean"
                    },
                    "nochange_reroll_count_freeze": {
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            },
            "cohort_size": {
              "minimum": 1,
              "type": "integer"
            },
            "description": {
              "pattern": ".*",
              "type": "string"
            },
            "duration": {
              "minimum": 0,
              "type": "integer"
            },
            "max_rolls": {
              "minimum": 0,
              "type": "integer"
            },
            "score_target": {
              "minimum": 0,
              "type": "integer"
            },
            "score_target_players": {
              "minimum": 0,
              "type": "integer"
            },
            "score_time_limit_sec": {
              "minimum": 0,
              "type": "integer"
            },
            "tier_delta_per_phase": {
              "minimum": 0,
              "type": "integer"
            },
            "roll_cooldown_sec": {
              "minimum": 0,
              "type": "integer"
            },
            "end_time_sec": {
              "minimum": 0,
              "type": "integer"
            },
            "max_idle_tier_drop": {
              "minimum": 0,
              "type": "integer"
            },
            "max_num_score": {
              "minimum": 0,
              "type": "integer"
            },
            "name": {
              "pattern": ".+",
              "type": "string"
            },
            "operator": {
              "enum": [
                "best",
                "set",
                "incr",
                "decr",
                "increment",
                "decrement"
              ],
              "type": "string"
            },
            "reset_schedule": {
              "type": "string"
            },
            "reward_tiers": {
              "patternProperties": {
                "[0-9]+": {
                  "items": {
                    "properties": {
                      "name": {
                        "type": "string"
                      },
                      "rank_max": {
                        "minimum": 0,
                        "type": "integer"
                      },
                      "rank_min": {
                        "minimum": 0,
                        "type": "integer"
                      },
                      "reward": {
                        "$ref": "Hiro-Rewards"
                      },
                      "tier_change": {
                        "type": "integer"
                      },
                      "roll_cooldown_sec": {
                        "minimum": 0,
                        "type": "integer"
                      },
                      "reroll_count_freeze": {
                        "type": "boolean"
                      }
                    },
                    "type": "object"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            },
            "start_time_sec": {
              "minimum": 0,
              "type": "integer"
            },
            "tier_overrides": {
              "patternProperties": {
                "[0-9]+": {
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "cohort_size": {
                      "minimum": 1,
                      "type": "integer"
                    },
                    "max_num_score": {
                      "minimum": 0,
                      "type": "integer"
                    },
                    "score_target": {
                      "minimum": 0,
                      "type": "integer"
                    },
                    "score_target_players": {
                      "minimum": 0,
                      "type": "integer"
                    },
                    "score_time_limit_sec": {
                      "minimum": 0,
                      "type": "integer"
                    },
                    "tier_delta_per_phase": {
                      "minimum": 0,
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            },
            "tiers": {
              "minimum": 1,
              "type": "integer"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "type": "object"
}
