                            ".+": {
                              "type": "integer"
                            }
                          },
                          "type": "object"
                        }
                      },
                      "type": "object"
                    },
                    "bid_start": {
                      "properties": {
                        "currencies": {
                          "patternProperties": {
                            ".+": {
                              "type": "integer"
                            }
                          },
                          "type": "object"
                        }
                      },
                      "type": "object"
                    },
                    "bid_increment": {
