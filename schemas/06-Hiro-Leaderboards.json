{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "leaderboards": {
      "items": {
        "properties": {
          "additional_properties": {
            "patternProperties": {
              ".+": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "authoritative": {
            "type": "boolean"
          },
          "ascending": {
            "type": "boolean"
          },
          "category": {
            "pattern": ".+",
            "type": "string"
          },
          "description": {
            "pattern": ".*",
            "type": "string"
          },
          "duration": {
            "minimum": 0,
            "type": "number"
          },
          "end_time_sec": {
            "minimum": 0,
            "type": "number"
          },
          "id": {
            "pattern": ".{1,}",
            "type": "string"
          },
          "name": {
            "pattern": ".+",
            "type": "string"
          },
          "operator": {
            "enum": [
              "best",
              "set",
              "incr",
              "decr",
              "increment",
              "decrement"
            ],
            "type": "string"
          },
          "regions": {
            "items": {
              "pattern": ".{1,}",
              "type": "string"
            },
            "type": "array"
          },
          "reset_schedule": {
            "type": "string"
          },
          "sort_order": {
            "enum": [
              "asc",
              "desc",
              "ascending",
              "descending"
            ],
            "type": "string"
          },
          "start_time_sec": {
            "minimum": 0,
            "type": "number"
          }
        },
        "required": [
          "id",
          "ascending",
          "operator",
          "authoritative"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "type": "object"
}
