{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "challenges": {
      "patternProperties": {
        ".+": {
          "properties": {
            "reward_tiers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "properties": {
                  "rank_max": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "rank_min": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "reward": {
                    "$ref": "Hiro-Rewards"
                  }
                }
              }
            },
            "additional_properties": {
              "patternProperties": {
                ".{1,}": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "max_num_score": {
              "minimum": 1,
              "type": "integer"
            },
            "start_delay_max_sec": {
              "minimum": 0,
              "type": "integer"
            },
            "ascending": {
              "type": "boolean"
            },
            "operator": {
                "enum": [
                    "best",
                    "set",
                    "incr",
                    "decr",
                    "increment",
                    "decrement"
                ],
                "type": "string"
            },
            "duration": {
              "properties": {
                "min_sec": {
                  "minimum": 0,
                  "type": "integer"
                },
                "max_sec": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "type": "object"
            },
            "players": {
              "properties": {
                "min": {
                  "minimum": 1,
                  "type": "integer"
                },
                "max": {
                  "minimum": 1,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          },
          "required": [
            "max_num_score", "ascending", "operator", "duration", "players"
          ],
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "type": "object"
}
